# ---- Python ----
.venv/
venv/
env/
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# ---- Local agent / tooling config (keep local only) ----
.claude/
.gstack/
.codex/
.cursor/

# ---- Environment / secrets ----
.env
.env.*
*.local

# ---- DOL data: raw is large (~80-140MB), processed is regenerable ----
# (contents ignored; the empty dirs are kept in git via .gitkeep so the
# documented quickstart — "save the xlsx into data/raw/" — works on a clean clone)
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# ---- Private outputs (the applicant's report contains portfolio + job-search data) ----
output/private/*
!output/private/.gitkeep

# ---- OS / editor cruft ----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.swp
*~
.idea/
.vscode/
